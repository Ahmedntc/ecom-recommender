# ── MLflow ────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=movielens-recommender

# ── Model ─────────────────────────────────────────────────
MODEL_EMBEDDING_DIM=64
MODEL_HIDDEN_DIMS=[256,128,64]
MODEL_DROPOUT=0.2
MODEL_LEARNING_RATE=0.001
MODEL_BATCH_SIZE=512
MODEL_MAX_EPOCHS=50
MODEL_EARLY_STOPPING_PATIENCE=5
MODEL_RANDOM_SEED=21

# ── Data ──────────────────────────────────────────────────
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_MIN_RATINGS_PER_USER=5
DATA_MIN_RATINGS_PER_MOVIE=5
DATA_TEST_SIZE=0.2
DATA_VAL_SIZE=0.1

# ── Paths ─────────────────────────────────────────────────
MODELS_PATH=models
LOGS_PATH=logs
